# AltilloJVG - Plantilla de Variables de Entorno
# Copia este archivo a .env en Vercel / Netlify / entorno local.
# NUNCA subas las claves reales al repositorio de GitHub.

# Token de Bot de Telegram (Obtenido desde @BotFather)
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyZ"

# ID de Canal o Grupo Privado de Telegram donde se almacenan los archivos
TELEGRAM_CHAT_ID="-1001234567890"

# URL Endpoint de API de Google Sheets (Stein / SheetDB / Google Apps Script WebApp)
# Ejemplo con Stein: https://api.steinhq.com/v1/storages/YOUR_STORAGE_ID/Aportes
SHEET_API_URL="https://api.steinhq.com/v1/storages/XXXXXX/Aportes"

# ID de Carpeta de Google Drive para archivos pesados (> 20MB)
GOOGLE_DRIVE_FOLDER_ID="1a2b3c4d5e6f7g8h9i0j"
